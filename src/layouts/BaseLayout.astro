---
import '../styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { SITE_NAME } from '@data/site';

interface Props {
  title: string;
  description: string;
  /** analytics context, stamped on <body> for the PostHog event payloads */
  articleSlug?: string;
  category?: string;
  contentType?: string;
  ogType?: string;
}

const { title, description, articleSlug, category, contentType, ogType = 'website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const POSTHOG_KEY = import.meta.env.PUBLIC_POSTHOG_KEY;
const POSTHOG_HOST = import.meta.env.PUBLIC_POSTHOG_HOST ?? 'https://us.i.posthog.com';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === SITE_NAME ? title : `${title} — ${SITE_NAME}`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_NAME} href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/rss.xml`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta name="twitter:card" content="summary" />
    <slot name="head" />
    {POSTHOG_KEY && (
      <script
        is:inline
        define:vars={{ POSTHOG_KEY, POSTHOG_HOST }}
      >
        /* PostHog snippet (official loader, trimmed) + HeavyHiker event wiring */
        !(function (t, e) {
          var o, n, p, r;
          e.__SV ||
            ((window.posthog = e),
            (e._i = []),
            (e.init = function (i, s, a) {
              function g(t, e) {
                var o = e.split('.');
                2 == o.length && ((t = t[o[0]]), (e = o[1])),
                  (t[e] = function () {
                    t.push([e].concat(Array.prototype.slice.call(arguments, 0)));
                  });
              }
              ((p = t.createElement('script')).type = 'text/javascript'),
                (p.crossOrigin = 'anonymous'),
                (p.async = !0),
                (p.src = s.api_host + '/static/array.js'),
                (r = t.getElementsByTagName('script')[0]).parentNode.insertBefore(p, r);
              var u = e;
              for (
                void 0 !== a ? (u = e[a] = []) : (a = 'posthog'),
                  u.people = u.people || [],
                  u.toString = function (t) {
                    var e = 'posthog';
                    return 'posthog' !== a && (e += '.' + a), t || (e += ' (stub)'), e;
                  },
                  u.people.toString = function () {
                    return u.toString(1) + '.people (stub)';
                  },
                  o = 'init capture register register_once unregister opt_out_capturing opt_in_capturing'.split(' '),
                  n = 0;
                n < o.length;
                n++
              )
                g(u, o[n]);
              e._i.push([i, s, a]);
            }),
            (e.__SV = 1));
        })(document, window.posthog || []);
        posthog.init(POSTHOG_KEY, { api_host: POSTHOG_HOST, capture_pageview: true, autocapture: false });

        document.addEventListener('DOMContentLoaded', function () {
          var body = document.body;
          var ctx = {
            article_slug: body.dataset.articleSlug || null,
            category: body.dataset.category || null,
            content_type: body.dataset.contentType || null,
          };

          if (ctx.article_slug) posthog.capture('article_view', ctx);

          /* affiliate_click — delegated so it covers every <AffiliateLink> */
          document.addEventListener('click', function (ev) {
            var a = ev.target && ev.target.closest ? ev.target.closest('a[data-affiliate-link]') : null;
            if (!a) return;
            posthog.capture('affiliate_click', {
              article_slug: ctx.article_slug,
              category: ctx.category,
              product_name: a.dataset.productName,
              brand: a.dataset.brand,
              position_on_page: a.dataset.position,
              cta_variant: a.dataset.ctaVariant,
            });
          });

          /* scroll_depth at 25/50/75/100 */
          var marks = [25, 50, 75, 100];
          var fired = {};
          function onScroll() {
            var doc = document.documentElement;
            var max = doc.scrollHeight - window.innerHeight;
            var pct = max <= 0 ? 100 : Math.round((window.scrollY / max) * 100);
            marks.forEach(function (m) {
              if (pct >= m && !fired[m]) {
                fired[m] = true;
                posthog.capture('scroll_depth', Object.assign({ depth: m }, ctx));
              }
            });
            if (fired[100]) window.removeEventListener('scroll', onScroll);
          }
          window.addEventListener('scroll', onScroll, { passive: true });

          /* comparison_table_sort — emitted by table-sort script as a DOM event */
          document.addEventListener('ol:table-sort', function (ev) {
            posthog.capture('comparison_table_sort', Object.assign({}, ctx, ev.detail));
          });

          /* time_on_page on tab hide/close */
          var t0 = Date.now();
          document.addEventListener('visibilitychange', function () {
            if (document.visibilityState === 'hidden') {
              posthog.capture('time_on_page', Object.assign({ seconds: Math.round((Date.now() - t0) / 1000) }, ctx));
            }
          });
        });
      </script>
    )}
  </head>
  <body
    class="min-h-screen bg-paper text-ink"
    data-article-slug={articleSlug}
    data-category={category}
    data-content-type={contentType}
  >
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:bg-rust focus:text-white focus:px-4 focus:py-2">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
