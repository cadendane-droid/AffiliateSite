---
/**
 * Table of contents with jump links — a fixture of high-performing affiliate
 * roundups. Built from the article's data; anchors match the section ids the
 * layout and components render.
 */
interface Props {
  productNames: string[];
  hasVerdict: boolean;
  hasCompetition: boolean;
  hasFaq: boolean;
}
const { productNames, hasVerdict, hasCompetition, hasFaq } = Astro.props;

const items: { href: string; label: string }[] = [];
if (hasVerdict) items.push({ href: '#verdict', label: 'The verdict' });
items.push({ href: '#comparison', label: 'Spec comparison' });
productNames.forEach((name, i) => items.push({ href: `#product-${i + 1}`, label: name }));
items.push({ href: '#how-we-picked', label: 'How we picked' });
if (hasCompetition) items.push({ href: '#competition', label: 'The competition' });
if (hasFaq) items.push({ href: '#faq', label: 'FAQ' });
---

<nav aria-label="In this article" class="not-prose rounded-sm border border-rule bg-paper-dark/60 px-4 py-3">
  <p class="text-[11px] font-bold uppercase tracking-widest text-ink-soft">In this guide</p>
  <ol class="mt-1.5 flex flex-wrap gap-x-4 gap-y-1 text-sm">
    {items.map((item) => (
      <li>
        <a href={item.href} class="text-pine underline underline-offset-2 decoration-rule hover:text-rust hover:decoration-rust">{item.label}</a>
      </li>
    ))}
  </ol>
</nav>
