---
/**
 * "The competition" — products evaluated and cut, with the honest reason.
 * Signals thoroughness to readers and covers long-tail product queries.
 */
interface Props {
  items: { name: string; brand: string; reason: string }[];
}
const { items } = Astro.props;
---

{items.length > 0 && (
  <section id="competition" class="not-prose my-8" aria-label="The competition">
    <h2 class="text-xl font-bold border-t border-rule pt-4">The competition: what we cut, and why</h2>
    <ul class="mt-3 space-y-2">
      {items.map((item) => (
        <li class="rounded-sm border border-rule bg-paper px-4 py-2.5 text-sm">
          <span class="font-bold">{item.name}</span>
          <span class="text-ink-soft"> ({item.brand})</span>
          <span class="text-ink-soft"> — {item.reason}</span>
        </li>
      ))}
    </ul>
  </section>
)}
