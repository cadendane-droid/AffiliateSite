---
import { url } from '@lib/url';
import { SITE_NAME, SITE_TAGLINE } from '@data/site';

const year = new Date().getFullYear();
const cols = [
  {
    title: 'Site',
    links: [
      { href: '/about/', label: 'About' },
      { href: '/how-we-review/', label: 'How We Review' },
      { href: '/authors/heavyhiker-editors/', label: 'Authors' },
      { href: '/contact/', label: 'Contact' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { href: '/affiliate-disclosure/', label: 'Affiliate Disclosure' },
      { href: '/privacy/', label: 'Privacy Policy' },
    ],
  },
  {
    title: 'Follow',
    links: [{ href: '/rss.xml', label: 'RSS Feed' }],
  },
];
---

<footer class="mt-16 border-t-2 border-ink bg-paper-dark">
  <div class="mx-auto max-w-5xl px-4 py-10 grid gap-8 sm:grid-cols-4">
    <div class="sm:col-span-1">
      <p class="font-bold">{SITE_NAME}</p>
      <p class="mt-1 text-sm text-ink-soft">{SITE_TAGLINE}</p>
    </div>
    {cols.map((col) => (
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-ink-soft">{col.title}</p>
        <ul class="mt-2 space-y-1 text-sm">
          {col.links.map((l) => (
            <li><a href={url(l.href)} class="hover:text-rust hover:underline underline-offset-4">{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="border-t border-rule">
    <div class="mx-auto max-w-5xl px-4 py-4 text-xs text-ink-soft space-y-2">
      <p>
        {SITE_NAME} is reader-supported. When you buy through links on this site, we may earn an affiliate
        commission at no extra cost to you. We do not accept payment for reviews or rankings.
        <a href={url('/affiliate-disclosure/')} class="underline underline-offset-2 hover:text-rust">Full disclosure</a>.
      </p>
      <p>
        Our reviews are research synthesis — manufacturer specs, verified owner reviews, and published third-party
        testing. We do not field-test products ourselves.
        <a href={url('/how-we-review/')} class="underline underline-offset-2 hover:text-rust">How we review</a>.
      </p>
      <p>© {year} {SITE_NAME}. All rights reserved.</p>
    </div>
  </div>
</footer>
