---
interface Props {
  faqs: { question: string; answer: string }[];
}
const { faqs } = Astro.props;
---

{faqs.length > 0 && (
  <section class="not-prose my-8" aria-label="Frequently asked questions">
    <h2 class="text-xl font-bold border-t border-rule pt-4">Frequently asked questions</h2>
    <div class="mt-3 divide-y divide-rule rounded-sm border border-rule">
      {faqs.map((f) => (
        <details class="group px-4 py-3 open:bg-paper-dark/40">
          <summary class="cursor-pointer list-none font-medium flex items-start justify-between gap-4">
            {f.question}
            <span class="text-rust font-mono group-open:rotate-45 transition-transform" aria-hidden="true">+</span>
          </summary>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{f.answer}</p>
        </details>
      ))}
    </div>
  </section>
)}
