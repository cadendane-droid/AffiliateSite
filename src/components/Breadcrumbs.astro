---
import { url } from '@lib/url';
import JsonLd from '@components/JsonLd.astro';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(url(c.href), Astro.site).toString() } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="text-xs text-ink-soft">
  <ol class="flex flex-wrap items-center gap-1">
    {crumbs.map((c, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true">/</span>}
        {c.href ? (
          <a href={url(c.href)} class="hover:text-rust hover:underline underline-offset-2">{c.label}</a>
        ) : (
          <span aria-current="page" class="text-ink">{c.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
<JsonLd data={jsonLd} />
