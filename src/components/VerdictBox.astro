---
/**
 * Top-of-article verdict: top pick / budget pick / lightweight pick.
 * Renders whichever awards exist in products[]. Sits within the first screen.
 */
import AffiliateLink from '@components/AffiliateLink.astro';
import { formatWeight } from '@lib/url';

interface ProductLike {
  name: string;
  brand: string;
  affiliateUrl: string;
  priceBand: string;
  weightOz: number | null;
  bestFor: string;
  award: 'top-pick' | 'budget-pick' | 'lightweight-pick' | null;
}

interface Props {
  products: ProductLike[];
}

const { products } = Astro.props;
const AWARD_LABELS: Record<string, string> = {
  'top-pick': 'Top pick',
  'budget-pick': 'Budget pick',
  'lightweight-pick': 'Lightweight pick',
};
const awarded = (['top-pick', 'budget-pick', 'lightweight-pick'] as const)
  .map((a) => products.find((p) => p.award === a))
  .filter((p): p is ProductLike => Boolean(p));
---

<section aria-label="Our verdict" class="rounded-sm border-2 border-ink bg-paper-dark p-4 sm:p-5">
  <h2 class="text-xs font-bold uppercase tracking-widest text-ink-soft">The verdict</h2>
  <div class="mt-3 grid gap-4 sm:grid-cols-3">
    {awarded.map((p) => (
      <div class="flex flex-col rounded-sm border border-rule bg-paper p-3">
        <span class="inline-block self-start rounded-sm bg-pine px-2 py-0.5 text-[11px] font-bold uppercase tracking-wide text-white">
          {AWARD_LABELS[p.award!]}
        </span>
        <p class="mt-2 font-bold leading-snug">{p.name}</p>
        <p class="font-mono text-xs text-ink-soft tabular">{formatWeight(p.weightOz)} · {p.priceBand}</p>
        <p class="mt-1 text-sm text-ink-soft grow">{p.bestFor}</p>
        <div class="mt-3">
          <AffiliateLink linkKey={p.affiliateUrl} position="verdict-box" ctaVariant="check-price" />
        </div>
      </div>
    ))}
  </div>
</section>
