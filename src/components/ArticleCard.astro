---
import type { CollectionEntry } from 'astro:content';
import { url, articlePath } from '@lib/url';
import { categoryMeta } from '@data/site';

interface Props {
  article: CollectionEntry<'articles'>;
}
const { article } = Astro.props;
const d = article.data;
const href = url(articlePath(d.contentType, d.category, d.slug));
const TYPE_LABEL: Record<string, string> = { roundup: 'Comparison', review: 'Review', guide: 'Guide' };
---

<a href={href} class="group flex h-full flex-col rounded-sm border border-rule bg-paper p-4 transition-colors hover:border-rust">
  <p class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-wider text-ink-soft">
    <span class="text-pine">{categoryMeta(d.category).title}</span>
    <span aria-hidden="true">·</span>
    <span>{TYPE_LABEL[d.contentType]}</span>
  </p>
  <h3 class="mt-1.5 font-bold leading-snug group-hover:text-rust">{d.title}</h3>
  <p class="mt-1.5 text-sm text-ink-soft grow">{d.description}</p>
  <p class="mt-3 font-mono text-xs text-ink-soft">
    Updated <time datetime={d.updatedDate.toISOString()}>{d.updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
  </p>
</a>
