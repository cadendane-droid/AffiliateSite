---
/**
 * Email capture stub. Posts nowhere until TODO_EMAIL_PROVIDER in
 * src/data/site.ts is replaced with a real provider endpoint.
 */
import { TODO_EMAIL_PROVIDER } from '@data/site';
const wired = TODO_EMAIL_PROVIDER !== 'TODO_EMAIL_PROVIDER';
---

<section class="rounded-sm border-2 border-ink bg-paper-dark p-5 sm:p-6" aria-label="Newsletter signup">
  <h2 class="text-lg font-bold">The Weigh-In</h2>
  <p class="mt-1 text-sm text-ink-soft max-w-prose">
    One email when we publish a new comparison. Verified weights, no hype, unsubscribe anytime.
  </p>
  <form class="mt-3 flex flex-wrap gap-2" method="post" action={wired ? TODO_EMAIL_PROVIDER : undefined} data-email-capture>
    <label class="sr-only" for="email-capture-input">Email address</label>
    <input
      id="email-capture-input"
      type="email"
      name="email"
      required
      placeholder="you@example.com"
      class="w-64 max-w-full rounded-sm border border-rule bg-paper px-3 py-2 text-sm focus:outline-2 focus:outline-rust"
      disabled={!wired}
    />
    <button
      type="submit"
      class="rounded-sm bg-ink px-4 py-2 text-sm font-bold text-white hover:bg-rust disabled:opacity-50"
      disabled={!wired}
    >
      Subscribe
    </button>
  </form>
  {!wired && <p class="mt-2 font-mono text-[11px] text-ink-soft">Signups open soon — provider not yet connected.</p>}
</section>
