---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ArticleCard from '@components/ArticleCard.astro';
import { url } from '@lib/url';
import { AUTHORS, getAuthor } from '@data/authors';

export function getStaticPaths() {
  return AUTHORS.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const author = getAuthor(slug);
const articles = (await getCollection('articles', ({ data }) => !data.draft && data.author === slug)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout title={author.name} description={author.bio.slice(0, 160)}>
  <div class="mx-auto max-w-5xl px-4 py-8">
    <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Authors' }, { label: author.name }]} />
    <h1 class="mt-4 text-3xl font-bold tracking-tight">{author.name}</h1>
    <p class="font-mono text-xs uppercase tracking-widest text-ink-soft mt-1">{author.role}</p>
    <p class="mt-4 max-w-2xl text-ink-soft leading-relaxed">{author.bio}</p>
    <p class="mt-2 text-sm">
      <a href={url('/how-we-review/')} class="text-rust underline underline-offset-2">Read the full methodology →</a>
    </p>

    <h2 class="mt-10 text-xl font-bold">Articles ({articles.length})</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {articles.map((a) => <ArticleCard article={a} />)}
    </div>
  </div>
</BaseLayout>
