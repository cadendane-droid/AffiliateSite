# PostHog analytics (https://posthog.com → Project Settings → API keys)
# The PUBLIC_ prefix exposes these to the client bundle — use the *project* key
# (write-only), never a personal API key.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Deployment URL. Defaults target GitHub Pages project hosting
# (https://cadendane-droid.github.io/AffiliateSite). When the custom domain is
# live, set SITE_URL=https://ounceledger.com and BASE_PATH=/
SITE_URL=
BASE_PATH=
